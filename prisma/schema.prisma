generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
    Viewer
    Analyst
    Admin
}

enum Type {
    Income
    Expense
}

model User {
    id        String   @id   @default(cuid())  
    name      String   @default("Newbie")
    email     String   @unique
    password  String
    role      Role
    isActive  Boolean  @default(false)
    records   Record[]
}

// Used one-to-many relationship
// Here date I massuming meant due date and should be taken as input
model Record {
    id           String   @id   @default(cuid())
    amount       Int            @default(0)
    type         Type
    category     String
    description  String         @default("No description")
    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt
    deletedAt    DateTime?

    userId    String
    user      User           @relation(fields: [userId], references: [id])
}